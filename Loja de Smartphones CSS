body {
background-image: url("img/tec.jpg");
background-size: cover;
background-repeat: no-repeat;

font-family: Arial;
}
table {
  border-collapse: collapse;
   width: 100%;
   height: 100%;
}
th {
	background-color:white;
	color: black;
	padding: 10px;	
	border: 1px solid black;
  }
 td{
	 padding: 10px;
	 text-align: center;
	 border: 1px solid black;
         
 }
/* --- Mudar a cor quando o cursor do mouse passar ---*/
 tr:hover {
	 background-color:#D386DB;
 }
 tr:nth-child(even){
	 background-color:white;
 }

