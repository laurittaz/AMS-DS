<h1>Contato</h1>

 <form action="#" method="post">
        <div class="form">
            <label for="nome" class="required">Nome</label>
            <input type="text" id="nome" name="nome" placeholder="Digite seu nome completo" maxlength="60" required>
        </div>

        <div class="form">
            <label for="email" class="required">E-mail</label>
            <input type="email" id="email" name="email" placeholder="seuemail@exemplo.com" maxlength="80" required>

        <div class="form">
            <label for="produto" class="required">Produto de interesse</label>
            <input type="text" id="produto" name="produto" placeholder="Ex: iPhone 16, iPhone 15, Acessórios..." maxlength="80" required>
           
        </div>
        <div class="form">
            <label for="mensagem" class="required">Mensagem</label>
            <input type="text" id="mensagem" name="mensagem" placeholder="Escreva sua dúvida, pedido ou sugestão..." maxlength="300" required>
            <div>
        	<br><br>
        <div class="botoes">
            <button type="submit">Enviar</button>
            <button type="reset">Limpar</button>
        </div>
    </form>
</div>

